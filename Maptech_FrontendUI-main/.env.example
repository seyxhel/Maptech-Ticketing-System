# Example environment variables for the frontend nginx template
# Copy to `.env` and customize for your environment.

# Preferred: set the full backend base URL (no trailing slash). The entrypoint
# will use this directly as `BACKEND_TARGET`.
# Example:
# BACKEND_URL=https://backend-production-ec3f.up.railway.app

# Alternatives (used to build BACKEND_TARGET when BACKEND_URL is not set):
# BACKEND_SCHEME: http or https (default: http)
# BACKEND_HOST: hostname or IP reachable from the frontend container (default: backend)
# BACKEND_PORT: port of the backend service (default: 8000)

# Examples:
BACKEND_URL=
#BACKEND_SCHEME=https
#BACKEND_HOST=backend-production-ec3f.up.railway.app
#BACKEND_PORT=8000

# Notes:
# - If you set BACKEND_URL, do NOT include a trailing slash.
# - The container computes BACKEND_TARGET at startup and substitutes it into nginx.
